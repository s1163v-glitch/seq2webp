{
  "name": "seq2webp",
  "version": "1.2.1",
  "description": "Image sequence to animated WebP/GIF converter",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "sharp": "^0.33.4",
    "fluent-ffmpeg": "^2.1.3",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^1.4.1"
  },
  "build": {
    "appId": "com.geolabs.seq2webp",
    "productName": "Seq2WebP",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [{"target": "portable", "arch": ["x64"]}],
      "icon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@ffmpeg-installer/**/*",
      "node_modules/@ffprobe-installer/**/*"
    ]
  }
}
